{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Description": "The AWS CloudFormation template for this Serverless application",
  "Resources": {
    "WebhookLogGroup": {
      "Type": "AWS::Logs::LogGroup",
      "Properties": {
        "LogGroupName": "/aws/lambda/adira-prod-webhook"
      }
    },
    "ProcessorLogGroup": {
      "Type": "AWS::Logs::LogGroup",
      "Properties": {
        "LogGroupName": "/aws/lambda/adira-prod-processor"
      }
    },
    "IamRoleLambdaExecution": {
      "Type": "AWS::IAM::Role",
      "Properties": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": [
                  "lambda.amazonaws.com"
                ]
              },
              "Action": [
                "sts:AssumeRole"
              ]
            }
          ]
        },
        "Policies": [
          {
            "PolicyName": {
              "Fn::Join": [
                "-",
                [
                  "adira",
                  "prod",
                  "lambda"
                ]
              ]
            },
            "PolicyDocument": {
              "Version": "2012-10-17",
              "Statement": [
                {
                  "Effect": "Allow",
                  "Action": [
                    "logs:CreateLogStream",
                    "logs:CreateLogGroup",
                    "logs:TagResource"
                  ],
                  "Resource": [
                    {
                      "Fn::Sub": "arn:${AWS::Partition}:logs:${AWS::Region}:${AWS::AccountId}:log-group:/aws/lambda/adira-prod*:*"
                    }
                  ]
                },
                {
                  "Effect": "Allow",
                  "Action": [
                    "logs:PutLogEvents"
                  ],
                  "Resource": [
                    {
                      "Fn::Sub": "arn:${AWS::Partition}:logs:${AWS::Region}:${AWS::AccountId}:log-group:/aws/lambda/adira-prod*:*:*"
                    }
                  ]
                },
                {
                  "Effect": "Allow",
                  "Action": [
                    "dynamodb:GetItem",
                    "dynamodb:PutItem",
                    "dynamodb:UpdateItem",
                    "dynamodb:DeleteItem",
                    "dynamodb:Query",
                    "dynamodb:Scan"
                  ],
                  "Resource": "arn:aws:dynamodb:ap-south-1:*:table/adira-teachers"
                },
                {
                  "Effect": "Allow",
                  "Action": [
                    "s3:GetObject",
                    "s3:PutObject",
                    "s3:DeleteObject",
                    "s3:ListBucket"
                  ],
                  "Resource": [
                    "arn:aws:s3:::adira-outputs",
                    "arn:aws:s3:::adira-outputs/*",
                    "arn:aws:s3:::adira-ncert-raw",
                    "arn:aws:s3:::adira-ncert-raw/*"
                  ]
                },
                {
                  "Effect": "Allow",
                  "Action": [
                    "sqs:SendMessage",
                    "sqs:ReceiveMessage",
                    "sqs:DeleteMessage",
                    "sqs:GetQueueAttributes"
                  ],
                  "Resource": "arn:aws:sqs:ap-south-1:*:adira-jobs"
                },
                {
                  "Effect": "Allow",
                  "Action": [
                    "secretsmanager:GetSecretValue"
                  ],
                  "Resource": "arn:aws:secretsmanager:ap-south-1:*:secret:adira/*"
                },
                {
                  "Effect": "Allow",
                  "Action": [
                    "sqs:ReceiveMessage",
                    "sqs:DeleteMessage",
                    "sqs:GetQueueAttributes"
                  ],
                  "Resource": [
                    "arn:aws:sqs:ap-south-1:951921971513:adira-jobs"
                  ]
                }
              ]
            }
          }
        ],
        "Path": "/",
        "RoleName": {
          "Fn::Join": [
            "-",
            [
              "adira",
              "prod",
              {
                "Ref": "AWS::Region"
              },
              "lambdaRole"
            ]
          ]
        }
      }
    },
    "WebhookLambdaFunction": {
      "Type": "AWS::Lambda::Function",
      "Properties": {
        "Code": {
          "S3Bucket": "serverless-framework-deployments-ap-south-1-e5df220b-a8ca",
          "S3Key": "serverless/adira/prod/1775038349004-2026-04-01T10:12:29.004Z/adira.zip"
        },
        "Handler": "src/lambdas/webhook.handler",
        "Runtime": "nodejs18.x",
        "FunctionName": "adira-prod-webhook",
        "MemorySize": 256,
        "Timeout": 10,
        "Environment": {
          "Variables": {
            "AWS_ACCOUNT_ID": "951921971513",
            "DYNAMODB_TABLE": "adira-teachers",
            "SQS_QUEUE_URL": "https://sqs.ap-south-1.amazonaws.com/951921971513/adira-jobs",
            "S3_OUTPUTS_BUCKET": "adira-outputs",
            "S3_RAW_BUCKET": "adira-ncert-raw",
            "VERIFY_TOKEN": "adira_secret_2026"
          }
        },
        "Role": {
          "Fn::GetAtt": [
            "IamRoleLambdaExecution",
            "Arn"
          ]
        }
      },
      "DependsOn": [
        "WebhookLogGroup"
      ]
    },
    "ProcessorLambdaFunction": {
      "Type": "AWS::Lambda::Function",
      "Properties": {
        "Code": {
          "S3Bucket": "serverless-framework-deployments-ap-south-1-e5df220b-a8ca",
          "S3Key": "serverless/adira/prod/1775038349004-2026-04-01T10:12:29.004Z/adira.zip"
        },
        "Handler": "src/lambdas/processor.handler",
        "Runtime": "nodejs18.x",
        "FunctionName": "adira-prod-processor",
        "MemorySize": 1024,
        "Timeout": 120,
        "Environment": {
          "Variables": {
            "AWS_ACCOUNT_ID": "951921971513",
            "DYNAMODB_TABLE": "adira-teachers",
            "SQS_QUEUE_URL": "https://sqs.ap-south-1.amazonaws.com/951921971513/adira-jobs",
            "S3_OUTPUTS_BUCKET": "adira-outputs",
            "S3_RAW_BUCKET": "adira-ncert-raw",
            "VERIFY_TOKEN": "adira_secret_2026"
          }
        },
        "Role": {
          "Fn::GetAtt": [
            "IamRoleLambdaExecution",
            "Arn"
          ]
        }
      },
      "DependsOn": [
        "ProcessorLogGroup"
      ]
    },
    "WebhookLambdaVersionlxlzJvae6k14WKiDVqFXoJXLLPzj3RcNl1hZrP4o88": {
      "Type": "AWS::Lambda::Version",
      "DeletionPolicy": "Retain",
      "Properties": {
        "FunctionName": {
          "Ref": "WebhookLambdaFunction"
        },
        "CodeSha256": "vxyKaiYfAUyNX5/bUKhHusgC5k56tJ9k8kIzLdcmAZY="
      }
    },
    "WebhookLambdaFunctionUrl": {
      "Type": "AWS::Lambda::Url",
      "Properties": {
        "AuthType": "NONE",
        "TargetFunctionArn": {
          "Fn::GetAtt": [
            "WebhookLambdaFunction",
            "Arn"
          ]
        }
      }
    },
    "WebhookLambdaPermissionFnUrl": {
      "Type": "AWS::Lambda::Permission",
      "Properties": {
        "FunctionName": {
          "Fn::GetAtt": [
            "WebhookLambdaFunction",
            "Arn"
          ]
        },
        "Action": "lambda:InvokeFunctionUrl",
        "Principal": "*",
        "FunctionUrlAuthType": "NONE"
      }
    },
    "WebhookLambdaPermissionFnUrlInvokeFunction": {
      "Type": "AWS::Lambda::Permission",
      "Properties": {
        "FunctionName": {
          "Fn::GetAtt": [
            "WebhookLambdaFunction",
            "Arn"
          ]
        },
        "Action": "lambda:InvokeFunction",
        "Principal": "*",
        "InvokedViaFunctionUrl": true
      }
    },
    "ProcessorLambdaVersionpVbOQc8NqNfC174KtqPKpj2oDQmkVJhNfOFlqlFkGx8": {
      "Type": "AWS::Lambda::Version",
      "DeletionPolicy": "Retain",
      "Properties": {
        "FunctionName": {
          "Ref": "ProcessorLambdaFunction"
        },
        "CodeSha256": "vxyKaiYfAUyNX5/bUKhHusgC5k56tJ9k8kIzLdcmAZY="
      }
    },
    "ProcessorEventSourceMappingSQSAdirajobs": {
      "Type": "AWS::Lambda::EventSourceMapping",
      "DependsOn": [
        "IamRoleLambdaExecution"
      ],
      "Properties": {
        "BatchSize": 1,
        "EventSourceArn": "arn:aws:sqs:ap-south-1:951921971513:adira-jobs",
        "FunctionName": {
          "Fn::GetAtt": [
            "ProcessorLambdaFunction",
            "Arn"
          ]
        },
        "Enabled": true
      }
    },
    "HttpApi": {
      "Type": "AWS::ApiGatewayV2::Api",
      "Properties": {
        "Name": "prod-adira",
        "ProtocolType": "HTTP"
      }
    },
    "HttpApiStage": {
      "Type": "AWS::ApiGatewayV2::Stage",
      "Properties": {
        "ApiId": {
          "Ref": "HttpApi"
        },
        "StageName": "$default",
        "AutoDeploy": true,
        "DefaultRouteSettings": {
          "DetailedMetricsEnabled": false
        }
      }
    },
    "WebhookLambdaPermissionHttpApi": {
      "Type": "AWS::Lambda::Permission",
      "Properties": {
        "FunctionName": {
          "Fn::GetAtt": [
            "WebhookLambdaFunction",
            "Arn"
          ]
        },
        "Action": "lambda:InvokeFunction",
        "Principal": "apigateway.amazonaws.com",
        "SourceArn": {
          "Fn::Join": [
            "",
            [
              "arn:",
              {
                "Ref": "AWS::Partition"
              },
              ":execute-api:",
              {
                "Ref": "AWS::Region"
              },
              ":",
              {
                "Ref": "AWS::AccountId"
              },
              ":",
              {
                "Ref": "HttpApi"
              },
              "/*"
            ]
          ]
        }
      }
    },
    "HttpApiIntegrationWebhook": {
      "Type": "AWS::ApiGatewayV2::Integration",
      "Properties": {
        "ApiId": {
          "Ref": "HttpApi"
        },
        "IntegrationType": "AWS_PROXY",
        "IntegrationUri": {
          "Fn::GetAtt": [
            "WebhookLambdaFunction",
            "Arn"
          ]
        },
        "PayloadFormatVersion": "2.0",
        "TimeoutInMillis": 30000
      }
    },
    "HttpApiRouteGetWebhook": {
      "Type": "AWS::ApiGatewayV2::Route",
      "Properties": {
        "ApiId": {
          "Ref": "HttpApi"
        },
        "RouteKey": "GET /webhook",
        "Target": {
          "Fn::Join": [
            "/",
            [
              "integrations",
              {
                "Ref": "HttpApiIntegrationWebhook"
              }
            ]
          ]
        }
      },
      "DependsOn": "HttpApiIntegrationWebhook"
    },
    "HttpApiRoutePostWebhook": {
      "Type": "AWS::ApiGatewayV2::Route",
      "Properties": {
        "ApiId": {
          "Ref": "HttpApi"
        },
        "RouteKey": "POST /webhook",
        "Target": {
          "Fn::Join": [
            "/",
            [
              "integrations",
              {
                "Ref": "HttpApiIntegrationWebhook"
              }
            ]
          ]
        }
      },
      "DependsOn": "HttpApiIntegrationWebhook"
    }
  },
  "Outputs": {
    "ServerlessDeploymentBucketName": {
      "Value": "serverless-framework-deployments-ap-south-1-e5df220b-a8ca",
      "Export": {
        "Name": "sls-adira-prod-ServerlessDeploymentBucketName"
      }
    },
    "WebhookLambdaFunctionQualifiedArn": {
      "Description": "Current Lambda function version",
      "Value": {
        "Ref": "WebhookLambdaVersionlxlzJvae6k14WKiDVqFXoJXLLPzj3RcNl1hZrP4o88"
      },
      "Export": {
        "Name": "sls-adira-prod-WebhookLambdaFunctionQualifiedArn"
      }
    },
    "WebhookLambdaFunctionUrl": {
      "Description": "Lambda Function URL",
      "Value": {
        "Fn::GetAtt": [
          "WebhookLambdaFunctionUrl",
          "FunctionUrl"
        ]
      },
      "Export": {
        "Name": "sls-adira-prod-WebhookLambdaFunctionUrl"
      }
    },
    "ProcessorLambdaFunctionQualifiedArn": {
      "Description": "Current Lambda function version",
      "Value": {
        "Ref": "ProcessorLambdaVersionpVbOQc8NqNfC174KtqPKpj2oDQmkVJhNfOFlqlFkGx8"
      },
      "Export": {
        "Name": "sls-adira-prod-ProcessorLambdaFunctionQualifiedArn"
      }
    },
    "HttpApiId": {
      "Description": "Id of the HTTP API",
      "Value": {
        "Ref": "HttpApi"
      },
      "Export": {
        "Name": "sls-adira-prod-HttpApiId"
      }
    },
    "HttpApiUrl": {
      "Description": "URL of the HTTP API",
      "Value": {
        "Fn::Join": [
          "",
          [
            "https://",
            {
              "Ref": "HttpApi"
            },
            ".execute-api.",
            {
              "Ref": "AWS::Region"
            },
            ".",
            {
              "Ref": "AWS::URLSuffix"
            }
          ]
        ]
      },
      "Export": {
        "Name": "sls-adira-prod-HttpApiUrl"
      }
    }
  }
}